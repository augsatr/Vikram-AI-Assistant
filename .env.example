# Vikram - JARVIS-like AI Assistant Configuration
# Copy this to .env and fill in your values

# Porcupine Wake Word - Get free key at https://console.picovoice.ai/
PORCUPINE_API_KEY=your_picovoice_api_key_here

# Wake word sensitivity (0.0 to 1.0, lower = more sensitive)
WAKE_WORD_SENSITIVITY=0.5

# Ollama model to use
OLLAMA_MODEL=qwen2.5

# Vikram's name (wake word response name)
VIKRAM_NAME=Vikram

# Audio settings
AUDIO_DEVICE_INDEX=-1
AUDIO_SAMPLE_RATE=16000
